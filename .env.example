# ─── TerraCube Sentinel — Environment Variables ─────────────────────────────
# Copy to .env and fill in real values: cp .env.example .env

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=sentinel
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_PORT=5432

# ─── TypeDB ──────────────────────────────────────────────────────────────────
TYPEDB_PORT=1729

# ─── MinIO (S3-compatible storage) ───────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ─── Valkey (Redis-compatible cache / event bus) ─────────────────────────────
VALKEY_PASSWORD=changeme_valkey
VALKEY_PORT=6379

# ─── Keycloak (OIDC / IAM) ──────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_keycloak
KEYCLOAK_PORT=8180

# ─── OpenMetadata ────────────────────────────────────────────────────────────
OM_MYSQL_ROOT_PASSWORD=changeme_om_root
OM_MYSQL_USER=openmetadata
OM_MYSQL_PASSWORD=changeme_om
OM_MYSQL_PORT=3306
OM_ES_PORT=9200
OM_PORT=8585

# ─── Prometheus ──────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090

# ─── Grafana ─────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_grafana
GRAFANA_PORT=3000

# ─── Loki ────────────────────────────────────────────────────────────────────
LOKI_PORT=3100
