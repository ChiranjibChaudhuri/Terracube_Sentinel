# ─── TerraCube Sentinel — Environment Variables ─────────────────────────────
# Copy to .env and fill in real values: cp .env.example .env

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=sentinel
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_PORT=5432

# ─── TypeDB ──────────────────────────────────────────────────────────────────
TYPEDB_PORT=1729

# ─── MinIO (S3-compatible storage) ───────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=terracube-satellite

# ─── Valkey (Redis-compatible cache / event bus) ─────────────────────────────
VALKEY_PASSWORD=changeme_valkey
VALKEY_PORT=6379
REDIS_URL=redis://:changeme_valkey@localhost:6379/0

# ─── Keycloak (OIDC / IAM) ──────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_keycloak
KEYCLOAK_PORT=8180

# ─── OpenMetadata ────────────────────────────────────────────────────────────
OM_MYSQL_ROOT_PASSWORD=changeme_om_root
OM_MYSQL_USER=openmetadata
OM_MYSQL_PASSWORD=changeme_om
OM_MYSQL_PORT=3306
OM_ES_PORT=9200
OM_PORT=8585

# ─── Elasticsearch (for OpenMetadata) ────────────────────────────────────────
ELASTIC_PASSWORD=changeme_elastic

# ─── Dagster ─────────────────────────────────────────────────────────────────
DAGSTER_POSTGRES_USER=dagster
DAGSTER_POSTGRES_PASSWORD=changeme_dagster
DAGSTER_POSTGRES_DB=dagster

# ─── Prometheus ──────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090

# ─── Grafana (port 3002 to avoid conflict with Dagster on 3000) ─────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_grafana
GRAFANA_PORT=3002

# ─── Loki ────────────────────────────────────────────────────────────────────
LOKI_PORT=3100

# ─── Open Foundry API ───────────────────────────────────────────────────────
FOUNDRY_API_URL=http://host.docker.internal:8080/api/v1
FOUNDRY_GRAPHQL_URL=http://host.docker.internal:8080/graphql
FOUNDRY_API_TOKEN=
# Backward-compatible alias; FOUNDRY_API_TOKEN is preferred.
FOUNDRY_TOKEN=

# ─── Frontend (Vite) ────────────────────────────────────────────────────────
VITE_API_URL=/agents
VITE_FOUNDRY_API_PROXY_TARGET=http://localhost:4000
VITE_FOUNDRY_GRAPHQL_PROXY_TARGET=http://localhost:4000

# ─── Ollama (LLM backend for AI agents) ─────────────────────────────────────
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ─── External Data API Keys ─────────────────────────────────────────────────
NASA_FIRMS_MAP_KEY=
FIRMS_API_KEY=DEMO_KEY
CDS_API_URL=https://cds.climate.copernicus.eu/api
CDS_API_KEY=
AWS_OPEN_DATA_REGION=us-west-2
MAX_CLOUD_COVER=20
STAC_LOOKBACK_HOURS=6
STAC_MAX_ITEMS=50
SATELLITE_LLM_MAX_ITEMS=10
SATELLITE_MAX_ASSETS_PER_SCENE=5
SATELLITE_ASSET_STORAGE_MODE=reference
SATELLITE_ASSET_KEYS=visual,red,green,blue,nir,nir08,swir16,swir22,scl,B04_10m,B08_10m,TCI_10m
OVERPASS_URL=https://overpass-api.de/api/interpreter
OSM_BBOX=-33.9,18.4,-33.7,18.7

# ─── Optional: Data Source APIs ──────────────────────────────────────────────
AIS_SOURCES=aishub,aisstream,gfw
AIS_API_URL=https://data.aishub.net/ws.php
AIS_API_KEY=
AISSTREAM_API_KEY=
AISSTREAM_WS_URL=wss://stream.aisstream.io/v0/stream
AISSTREAM_SNAPSHOT_SECONDS=30
AISSTREAM_MAX_MESSAGES=5000
# south,west,north,east; omit for global aisstream snapshots
AISSTREAM_BBOX=
AISSTREAM_BBOX_FORMAT=corners
GFW_API_TOKEN=
GFW_API_URL=https://gateway.api.globalfishingwatch.org/v3/4wings/report
GFW_DATASET=public-global-presence:latest
# south,west,north,east; recommended for GFW report size control
GFW_BBOX=
GFW_LOOKBACK_HOURS=24
GFW_MAX_RECORDS=1000
WAQI_API_TOKEN=

# ─── Alerting (optional) ────────────────────────────────────────────────────
ALERT_WEBHOOK_URL=
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
ALERT_FROM_EMAIL=sentinel@terracube.io
ALERT_TO_EMAILS=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── Action Webhooks ────────────────────────────────────────────────────────
DAGSTER_WEBHOOK_URL=http://dagster-webserver:3000/api/v1/webhooks
NOTIFICATION_WEBHOOK_URL=http://agents:8001/webhooks

# ─── LLM Backend (AI Ingestion Pipeline) ───────────────────────────────────
# Supported backends: "openai" (GLM-5 Turbo / ZAI / OpenAI-compatible), "ollama" (local)
LLM_BACKEND=openai
LLM_BASE_URL=https://api.z.ai/api/coding/paas/v4
LLM_MODEL=glm-5-turbo
ZAI_API_KEY=
# Fallback: if ZAI_API_KEY is empty, the system checks OPENAI_API_KEY
OPENAI_API_KEY=
AI_ENABLE_LLM_CLASSIFICATION=true
AI_ENABLE_ANOMALY_DETECTION=true
AI_ENABLE_AUTO_MAPPING=true

# ─── Superset ───────────────────────────────────────────────────────────────
SUPERSET_SECRET_KEY=changeme-superset-secret-key
