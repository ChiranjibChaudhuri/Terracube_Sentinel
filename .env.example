# ─── TerraCube Sentinel — Environment Variables ─────────────────────────────
# Copy to .env and fill in real values: cp .env.example .env

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=sentinel
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_PORT=5432

# ─── TypeDB ──────────────────────────────────────────────────────────────────
TYPEDB_PORT=1729

# ─── MinIO (S3-compatible storage) ───────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ─── Valkey (Redis-compatible cache / event bus) ─────────────────────────────
VALKEY_PASSWORD=changeme_valkey
VALKEY_PORT=6379

# ─── Keycloak (OIDC / IAM) ──────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_keycloak
KEYCLOAK_PORT=8180

# ─── OpenMetadata ────────────────────────────────────────────────────────────
OM_MYSQL_ROOT_PASSWORD=changeme_om_root
OM_MYSQL_USER=openmetadata
OM_MYSQL_PASSWORD=changeme_om
OM_MYSQL_PORT=3306
OM_ES_PORT=9200
OM_PORT=8585

# ─── Prometheus ──────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090

# ─── Grafana (port 3002 to avoid conflict with Dagster on 3000) ─────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_grafana
GRAFANA_PORT=3002

# ─── Loki ────────────────────────────────────────────────────────────────────
LOKI_PORT=3100

# ─── Open Foundry API ───────────────────────────────────────────────────────
FOUNDRY_API_URL=http://host.docker.internal:8080/api/v1
FOUNDRY_API_TOKEN=

# ─── Ollama (LLM backend for AI agents) ─────────────────────────────────────
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ─── External Data API Keys ─────────────────────────────────────────────────
NASA_FIRMS_MAP_KEY=
FIRMS_API_KEY=DEMO_KEY
CDS_API_KEY=

# ─── Optional: Data Source APIs ──────────────────────────────────────────────
AIS_API_KEY=
WAQI_API_TOKEN=

# ─── Alerting (optional) ────────────────────────────────────────────────────
ALERT_WEBHOOK_URL=
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Superset ───────────────────────────────────────────────────────────────
SUPERSET_SECRET_KEY=changeme-superset-secret-key
